# Dependencies
node_modules/

# Build output — ignore everything in dist/ EXCEPT our tracked loader page.
# The loader (dist/index.html) is what Tauri ships as the initial window;
# it polls Mission Control and redirects. See src-tauri/tauri.conf.json.
dist/*
!dist/index.html

# Rust
src-tauri/target/
src-tauri/Cargo.lock

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*